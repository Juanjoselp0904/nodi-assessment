# LLM / STT / TTS
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=...
GOOGLE_APPLICATION_CREDENTIALS=./google_service_account.json

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite:///./nodi.db

# Storage (leave R2 vars empty to use local filesystem)
STORAGE_PATH=./storage
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# Frontend URL for CORS (set in production)
FRONTEND_URL=
